---
import Base from "@/layouts/Base.astro";
import PageHero from "@/components/PageHero.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import TourCard from "@/components/TourCard.astro";
import Frieze from "@/components/Frieze.astro";
import CustomTrip from "@/components/conversion/CustomTrip.astro";
import { multidayTours, dayTours, tours } from "@/data/tours";
import { breadcrumb, collectionSchema } from "@/schemas/jsonld";

const jsonld = [
  breadcrumb([["Home", "index.html"], ["Tours", "tours.html"]]),
  ...collectionSchema(
    "Egypt Tours & Private Journeys",
    "Twenty-five private Egypt tours — Nile cruises, multi-day journeys, Red Sea escapes and full-day experiences.",
    "tours.html",
    tours.map((t) => ({ title: t.title, slug: t.slug, domain: "tour" })),
  ),
];
---
<Base
  title="Egypt Tours & Nile Cruises — 25 Private Journeys | Kemet"
  description="Twenty-five private Egypt tours by Kemet — Nile cruises, honeymoon and family journeys, Red Sea escapes, Abu Simbel and day tours of Giza, Saqqara, Cairo and Alexandria. EUR, per person."
  active="tours.html"
  jsonld={jsonld}
>
  <PageHero
    crumb="Tours"
    symbol="ankh"
    title="The Journeys"
    text="Twenty-five private itineraries across Egypt. Prices are per person in euros and already include our guiding, entrance fees, lunches and private transfers."
    heroSrc="/images/giza/giza-sound-and-light-show.webp"
    heroAlt="The Sound and Light show illuminating the Pyramids of Giza after dark"
    heroWidth={1200}
    heroHeight={800}
  />

  <section style="padding-top:30px">
    <div class="wrap">
      <SectionHeader
        eyebrow="Multi-day"
        title="Signature journeys"
        text="Two to fourteen days — five-star hotels, Nile cruises between Aswan and Luxor, honeymoon and family journeys, and Red Sea escapes to close the trip."
      />
      <div class="grid-3">
        {multidayTours.map((tour) => <TourCard tour={tour} />)}
      </div>
    </div>
  </section>

  <Frieze />

  <section>
    <div class="wrap">
      <SectionHeader
        eyebrow="Day tours"
        title="Day tours & excursions"
        text="Self-contained full, half and evening tours from Cairo and Aswan — perfect on their own or as additions to a longer stay."
      />
      <div class="grid-3">
        {dayTours.map((tour) => <TourCard tour={tour} />)}
      </div>
    </div>
  </section>

  <CustomTrip />
</Base>
