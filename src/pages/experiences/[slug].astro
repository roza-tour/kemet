---
// Experience detail (/experiences/<slug>.html). ONE template renders every
// experience from data — adding an experience is data-only, no edit here.
//
// Sections are composed from generic, reusable primitives (ExperienceHero,
// FactList, HighlightList, Faq, ExperienceCard, DestinationCard, TourCard,
// LeadCapture). There is no per-experience logic and no experience-specific
// markup. Every block is gated on the presence of its data so a sparser or
// richer experience renders correctly with no template change.
// Relationships come from the content registry, never hardcoded.
import Base from "@/layouts/Base.astro";
import Frieze from "@/components/Frieze.astro";
import Faq from "@/components/Faq.astro";
import Placeholder from "@/components/Placeholder.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import TourCard from "@/components/TourCard.astro";
import FactList from "@/components/destination/FactList.astro";
import HighlightList from "@/components/destination/HighlightList.astro";
import DestinationCard from "@/components/destination/DestinationCard.astro";
import ExperienceHero from "@/components/experience/ExperienceHero.astro";
import ExperienceCard from "@/components/experience/ExperienceCard.astro";
import LeadCapture from "@/components/conversion/LeadCapture.astro";
import { experiences } from "@/data/experiences";
import { registry, resolveRelatedExperiences, relatedTours } from "@/data/registry";
import { entityStaticPaths, relativePrefix, routeFor } from "@/config/routes";
import { entitySchema } from "@/schemas/jsonld";
import type { Destination, Tour, Experience } from "@/types";

interface Props {
  entity: Experience;
}

// One static page per experience → experiences/sunrise-giza-pyramids.html, etc.
export function getStaticPaths() {
  return entityStaticPaths(experiences);
}

const experience = Astro.props.entity;
const route = routeFor("experience", experience.slug);
const base = relativePrefix(route);

// Resolve relationships from the registry — never hardcoded.
const relDestinations = registry.resolve<Destination>(
  experience.relationships?.destinations ?? [],
);
const relExperiences = resolveRelatedExperiences(experience);

// Aggregate related tours from all linked destinations (deduplicated by slug).
const seenTourSlugs = new Set<string>();
const relTours: Tour[] = [];
for (const dest of relDestinations) {
  for (const tour of relatedTours(dest.id)) {
    if (!seenTourSlugs.has(tour.slug)) {
      seenTourSlugs.add(tour.slug);
      relTours.push(tour);
    }
  }
}

const title = experience.seo?.title ?? `${experience.title} — ${experience.durationLabel} | Kemet Egypt`;
const description = experience.seo?.description ?? experience.shortSummary;
const jsonld = entitySchema("experience", experience);
---
<Base title={title} description={description} active={route} jsonld={jsonld}>
  <article>
    <ExperienceHero experience={experience} base={base} />

    <section style="padding-top:20px">
      <div class="wrap">
        <div class="tdetail">

          {/* ---- Left column: main content ---- */}
          <div>
            <div class="tblock reveal">
              <h2>Overview</h2>
              <p>{experience.longDescription}</p>
            </div>

            {experience.highlights && experience.highlights.length > 0 && (
              <div class="tblock reveal">
                <h2>Highlights</h2>
                <HighlightList items={experience.highlights} variant="check" />
              </div>
            )}

            {(experience.whatsIncluded || experience.whatsExcluded) && (
              <div class="tblock reveal inc">
                <h2>Included &amp; not included</h2>
                <div class="grid-2">
                  {experience.whatsIncluded && experience.whatsIncluded.length > 0 && (
                    <div>
                      <h3>Included</h3>
                      <ul>
                        {experience.whatsIncluded.map((item) => <li>{item}</li>)}
                      </ul>
                    </div>
                  )}
                  {experience.whatsExcluded && experience.whatsExcluded.length > 0 && (
                    <div>
                      <h3>Not included</h3>
                      <ul class="no">
                        {experience.whatsExcluded.map((item) => <li>{item}</li>)}
                      </ul>
                    </div>
                  )}
                </div>
              </div>
            )}

            {experience.preparationTips && experience.preparationTips.length > 0 && (
              <div class="tblock reveal">
                <h2>Preparation</h2>
                <HighlightList items={experience.preparationTips} variant="dot" />
              </div>
            )}

            {experience.goodToKnow && experience.goodToKnow.length > 0 && (
              <div class="tblock reveal">
                <h2>Good to know</h2>
                <HighlightList items={experience.goodToKnow} variant="dot" />
              </div>
            )}

            {experience.faqs && experience.faqs.length > 0 && (
              <div class="reveal">
                <Faq items={experience.faqs} heading="Frequently asked questions" />
              </div>
            )}
          </div>

          {/* ---- Right sidebar ---- */}
          <aside class="side">
            {experience.keyFacts && experience.keyFacts.length > 0 && (
              <div class="pcard reveal">
                <div class="eyebrow" style="margin-bottom:4px">Quick facts</div>
                <FactList items={experience.keyFacts} />

                {(experience.availabilityNote || experience.priceNote) && (
                  <div style="margin-top:20px;padding-top:18px;border-top:1px solid var(--line)">
                    {experience.priceNote && (
                      <p style="font-size:.85rem;color:var(--muted);margin-bottom:8px">
                        {experience.priceNote}
                      </p>
                    )}
                    {experience.availabilityNote && (
                      <p style="font-size:.82rem;color:var(--muted-2)">
                        {experience.availabilityNote}
                      </p>
                    )}
                  </div>
                )}
              </div>
            )}

            {experience.meetingPointNote && (
              <div class="pcard reveal" style="margin-top:20px">
                <div class="eyebrow" style="margin-bottom:8px">Meeting point</div>
                <p style="font-size:.88rem;color:var(--muted)">{experience.meetingPointNote}</p>
              </div>
            )}
          </aside>

        </div>
      </div>
    </section>

    <Frieze />

    {experience.gallery && experience.gallery.length > 0 && (
      <section>
        <div class="wrap">
          <SectionHeader eyebrow="Gallery" title="In photographs" />
          <div class="grid-2">
            {experience.gallery.map((g) => (
              <Placeholder
                class="tgallery reveal cur"
                src={g.src}
                alt={g.alt}
                width={g.width}
                height={g.height}
                label={g.label ?? experience.title}
              />
            ))}
          </div>
        </div>
      </section>
    )}

    {relDestinations.length > 0 && (
      <section>
        <div class="wrap">
          <SectionHeader
            eyebrow="Destinations"
            title="Where this experience takes place"
          />
          <div class="grid-3">
            {relDestinations.map((d) => (
              <DestinationCard destination={d} base={base} />
            ))}
          </div>
        </div>
      </section>
    )}

    {relTours.length > 0 && (
      <section>
        <div class="wrap">
          <SectionHeader eyebrow="Journeys" title="Tours that visit this area" />
          <div class="grid-3">
            {relTours.map((tour) => (
              <TourCard tour={tour} base={base} />
            ))}
          </div>
        </div>
      </section>
    )}

    {relExperiences.length > 0 && (
      <section>
        <div class="wrap">
          <SectionHeader eyebrow="Similar experiences" title="You may also like" />
          <div class="grid-3">
            {relExperiences.map((e) => (
              <ExperienceCard experience={e} base={base} />
            ))}
          </div>
        </div>
      </section>
    )}

    <LeadCapture
      variant="expert"
      whatsappMessage={`Hello Kemet — I'm interested in the "${experience.title}" experience and would like more information.`}
      emailSubject={`Enquiry: ${experience.title} — Kemet Egypt`}
    />
  </article>
</Base>
