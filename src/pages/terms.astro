---
// Terms of Use (/terms.html). Content lives in src/data/legal.ts.
import Base from "@/layouts/Base.astro";
import PageHero from "@/components/PageHero.astro";
import LegalContent from "@/components/trust/LegalContent.astro";
import { termsOfService } from "@/data/legal";
import { canonical } from "@/utils/links";
import { site, SITE_URL } from "@/config/site";

const ROUTE = "terms.html";
const jsonld = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: `Terms of Use — ${site.name}`,
  url: canonical(ROUTE),
  isPartOf: { "@type": "WebSite", name: `${site.name} — The Black Land`, url: SITE_URL },
};
---
<Base
  title={`Terms of Use — ${site.name}`}
  description="The terms governing use of the Kemet website, enquiries and quotes. Read alongside our Booking & Cancellation terms for confirmed trips."
  active={ROUTE}
  jsonld={jsonld}
>
  <PageHero
    crumb="Terms of Use"
    symbol="ankh"
    title="Terms of Use"
    text="The terms behind our website, enquiries and quotes — written plainly, and read alongside our Booking & Cancellation terms."
    heroSrc="/images/cairo/cairo-citadel-mosque-dusk.webp"
    heroAlt="The Citadel of Cairo and its mosque silhouetted at dusk"
    heroWidth={1600}
    heroHeight={1066}
  />
  <section style="padding-top:26px">
    <div class="wrap">
      <LegalContent doc={termsOfService} />
    </div>
  </section>
</Base>
