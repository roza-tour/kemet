---
import { primaryNav } from "@/config/navigation";

interface Props {
  /** Route file of the active page, e.g. "tours.html". */
  active?: string;
  /** Link prefix back to the site root ("" at root, "../" in subfolders). */
  base?: string;
}
const { active = "index.html", base = "" } = Astro.props;
---
<nav class="nav" id="nav">
  <a class="brand" href={`${base}index.html`} aria-label="Kemet — Luxury Egypt Travel — home">
    <img src="/images/brand/kemet-logo-transparent.png" alt="Kemet — Luxury Egypt Travel" width="120" height="46" decoding="async" style="height:46px;width:auto;display:block" />
  </a>
  <div class="navlinks" id="navlinks">
    {primaryNav.map(({ href, label }) => (
      <a href={`${base}${href}`} class={href === active ? "active" : undefined} aria-current={href === active ? "page" : undefined}>{label}</a>
    ))}
  </div>
  <a href={`${base}tours.html`} class="nav-cta">Plan a Journey</a>
  <button class="burger" aria-label="Open menu" aria-expanded="false" aria-controls="navlinks">&#9776;</button>
</nav>
