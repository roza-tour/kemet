---
// WhatsAppButton — a single floating WhatsApp affordance, pinned to the
// bottom-right of every page (no scroll trigger, no email button).
// Replaces the old scroll-activated MobileConversionBar. Always visible so a
// visitor can reach us in one tap from anywhere on the site.
// The number + pre-filled message come from centralized config via links.ts.
import { whatsappLink } from "@/utils/links";

interface Props {
  /** Pre-filled WhatsApp message. */
  message?: string;
  /** Short greeting shown in the hover/focus bubble. */
  label?: string;
}

const {
  message = "Hello Kemet — I'd like to plan an Egypt journey.",
  label = "Chat with us on WhatsApp",
} = Astro.props;

const waHref = whatsappLink(message);
---

{/* Floating WhatsApp button — see global.css .wafab-* rules. */}
<a
  href={waHref}
  class="wafab"
  target="_blank"
  rel="noopener"
  aria-label={label}
>
  <span class="wafab-bubble" aria-hidden="true">{label}</span>
  <span class="wafab-ring" aria-hidden="true"></span>
  <svg class="wafab-icon" viewBox="0 0 32 32" width="30" height="30" aria-hidden="true" focusable="false">
    <path
      fill="currentColor"
      d="M16.04 4C9.9 4 4.92 8.98 4.92 15.12c0 2.05.55 4.05 1.6 5.8L4.8 27l6.24-1.64a11.05 11.05 0 0 0 5 1.2h.01c6.13 0 11.12-4.98 11.12-11.12S22.18 4 16.04 4Zm0 20.3h-.01c-1.55 0-3.07-.42-4.4-1.2l-.31-.19-3.7.97.99-3.61-.2-.32a9.16 9.16 0 0 1-1.4-4.85c0-5.06 4.12-9.18 9.2-9.18 2.45 0 4.76.96 6.5 2.7a9.13 9.13 0 0 1 2.69 6.49c0 5.06-4.12 9.18-9.16 9.18Zm5.03-6.87c-.28-.14-1.63-.8-1.88-.9-.25-.09-.43-.14-.61.14-.18.28-.7.9-.86 1.08-.16.18-.32.2-.6.07-.28-.14-1.16-.43-2.22-1.37-.82-.73-1.37-1.63-1.53-1.91-.16-.28-.02-.43.12-.57.13-.13.28-.32.42-.48.14-.16.18-.28.28-.46.09-.18.05-.35-.02-.49-.07-.14-.61-1.48-.84-2.02-.22-.53-.44-.46-.61-.47l-.52-.01c-.18 0-.47.07-.72.35-.25.28-.95.93-.95 2.27s.97 2.63 1.11 2.81c.14.18 1.9 2.9 4.6 4.07.64.28 1.14.44 1.53.57.64.2 1.23.17 1.69.1.52-.08 1.63-.66 1.86-1.3.23-.64.23-1.19.16-1.3-.07-.12-.25-.19-.53-.33Z"
    ></path>
  </svg>
</a>
