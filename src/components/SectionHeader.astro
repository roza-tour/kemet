---
// SectionHeader — eyebrow + heading + gold rule + optional lede. When `no` is
// given, a giant outlined numeral watermark floats behind the heading.
interface Props {
  eyebrow?: string;
  title: string;
  text?: string;
  /** Editorial section number, e.g. "01" — rendered as an outlined watermark. */
  no?: string;
}
const { eyebrow, title, text = "", no } = Astro.props;
---
<div class="sec-head reveal" data-no={no}>
  {eyebrow && <div class="eyebrow">{eyebrow}</div>}
  <h2>{title}</h2>
  <div class="rule"></div>
  {text && <p>{text}</p>}
  <slot />
</div>
