---
// PageHero — the centred header used by every inner page: breadcrumb, an
// optional gold symbol, the H1 and a short lede. An optional hero image renders
// full-width beneath the header when `heroSrc` is supplied.
import SymbolIcon from "@/components/SymbolIcon.astro";
import Placeholder from "@/components/Placeholder.astro";

interface Props {
  title: string;
  text?: string;
  /** SymbolIcon name to show above the heading. */
  symbol?: string;
  /** Breadcrumb leaf label (Home is prepended automatically). */
  crumb?: string;
  /** Link prefix back to the site root ("" at root, "../" in subfolders). */
  base?: string;
  /** Optional hero photo shown beneath the header. */
  heroSrc?: string;
  heroAlt?: string;
  heroWidth?: number;
  heroHeight?: number;
}
const {
  title, text = "", symbol = "", crumb = "", base = "",
  heroSrc, heroAlt, heroWidth, heroHeight,
} = Astro.props;
---
<header class="phero">
  <div class="wrap">
    {crumb && (
      <nav class="crumb" aria-label="Breadcrumb">
        <a href={`${base}index.html`}>Home</a> · <span>{crumb}</span>
      </nav>
    )}
    {symbol && <div class="sym"><SymbolIcon name={symbol} /></div>}
    <h1>{title}</h1>
    {text && <p>{text}</p>}
  </div>
</header>
{heroSrc && (
  <section style="padding-top:18px;padding-bottom:0">
    <div class="wrap">
      <Placeholder class="tgallery reveal cur" src={heroSrc} alt={heroAlt ?? title} width={heroWidth} height={heroHeight} loading="eager" />
    </div>
  </section>
)}
