---
// SymbolIcon — a small library of inline, gold SVG glyphs used across the site
// (identity symbols, pharaonic gods, friezes, craft markers).
//
// All glyphs share a 0 0 100 100 viewBox and paint themselves with the
// site-wide gold gradient `url(#g)` (defined once in Base.astro) plus a
// literal gold stroke, so they need no per-instance styling.
//
// Usage: <SymbolIcon name="ankh" title="Ankh — key of life" />
interface Props {
  /** Glyph key — see the G map below. */
  name: string;
  /** Accessible label; when omitted the icon is decorative. */
  title?: string;
  class?: string;
}
const { name, title = "", class: className = "" } = Astro.props;

type Glyph = string;
const G: Record<string, Glyph> = {
  // Pharaonic — key of life
  ankh: `<g fill="none" stroke="url(#g)" stroke-width="6" stroke-linecap="round">
    <ellipse cx="50" cy="29" rx="14" ry="18"/>
    <path d="M50 47 V88"/>
    <path d="M30 58 H70"/>
  </g>`,
  // Nubian — solar disc with rays
  sun: `<g stroke="url(#g)" stroke-width="5" stroke-linecap="round">
    <circle cx="50" cy="50" r="15" fill="url(#g)" stroke="none"/>
    ${Array.from({ length: 12 }, (_, i) => {
      const a = (i * Math.PI) / 6;
      const x1 = 50 + Math.cos(a) * 24, y1 = 50 + Math.sin(a) * 24;
      const x2 = 50 + Math.cos(a) * 36, y2 = 50 + Math.sin(a) * 36;
      return `<path d="M${x1.toFixed(1)} ${y1.toFixed(1)} L${x2.toFixed(1)} ${y2.toFixed(1)}"/>`;
    }).join("")}
  </g>`,
  // Coptic — flared equal-armed cross
  cross: `<g fill="url(#g)">
    <path d="M44 16 H56 V44 H84 V56 H56 V90 H44 V56 H16 V44 H44 Z"/>
    <circle cx="50" cy="14" r="4"/><circle cx="50" cy="92" r="4"/>
    <circle cx="14" cy="50" r="4"/><circle cx="86" cy="50" r="4"/>
  </g>`,
  // Islamic — crescent and star
  crescent: `<g fill="url(#g)">
    <path d="M70 18a34 34 0 1 0 0 64 27 27 0 1 1 0-64Z"/>
    <path d="M76 38 l4.5 9.2 10.2 1.5-7.4 7.2 1.7 10.1-9-4.8-9 4.8 1.7-10.1-7.4-7.2 10.2-1.5Z"/>
  </g>`,
  // Bedouin · Sinai — camel silhouette
  camel: `<g fill="url(#g)">
    <path d="M11 40c2-1 4 0 5 3 1 4 3 6 6 6 2 4 4 6 7 7l2 22c0 2 2 3 4 3s3-1 3-3l-1-21h12l1 6c-2 1-3 3-3 6l1 12c0 2 2 3 4 3s3-1 3-3l-1-15c4-3 7-8 9-15 3-12 9-18 16-19 3 0 5-1 6-3 2-3 5-4 8-3 2 0 3-1 3-3s-2-4-5-4c-5-1-9 1-12 5-1 1-3 2-5 2-9 1-16 5-21 12-3-5-7-8-13-9-3-7-6-11-10-12-4-2-8-1-11 2-3-2-6-2-9 0-3 1-5 3-6 6-2 1-4 2-5 4-1 2-1 4 0 5Z"/>
    <path d="M30 60l-3 12 4 1 3-12Z"/>
  </g>`,
  // Greco-Roman — classical column
  greco: `<g fill="url(#g)">
    <path d="M22 18h56v8H22z"/>
    <path d="M26 26h48v6H26z"/>
    <path d="M30 32q20 6 40 0v4q-20 6-40 0z"/>
  </g>
  <g fill="none" stroke="url(#g)" stroke-width="4">
    <path d="M36 40v40M50 40v40M64 40v40"/>
  </g>
  <g fill="url(#g)">
    <path d="M30 80h40v6H30z"/>
    <path d="M24 86h52v8H24z"/>
  </g>`,
  // Siwan · Amazigh — palm
  palm: `<g fill="none" stroke="url(#g)" stroke-width="5" stroke-linecap="round">
    <path d="M50 90V44"/>
    <path d="M50 44C40 30 28 26 16 28M50 44C42 26 40 16 44 10M50 44C58 26 60 16 56 10M50 44C60 30 72 26 84 28M50 44C36 36 26 36 18 42M50 44C64 36 74 36 82 42"/>
  </g>
  <circle cx="50" cy="42" r="5" fill="url(#g)"/>`,
  // The Red Sea — fish
  fish: `<g fill="url(#g)">
    <path d="M14 50c10-16 30-24 48-22 8 1 14 4 18 9-4 5-10 8-18 9-18 2-38-6-48-5Z" fill="none" stroke="url(#g)" stroke-width="5" stroke-linejoin="round"/>
    <path d="M80 37c6-4 11-5 14-4-2 6-2 11 0 17-3 1-8 0-14-4Z"/>
    <circle cx="34" cy="44" r="3.5"/>
  </g>`,
  // Eye of Horus (wedjat)
  eye: `<g fill="none" stroke="url(#g)" stroke-width="5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M16 50c10-12 26-18 42-15 9 2 16 7 22 14-9 5-20 8-32 7C34 55 24 53 16 50Z"/>
    <path d="M22 38c10-8 24-12 38-9"/>
    <path d="M40 60l-6 22"/>
    <path d="M58 60c4 10 1 18-9 20 6-6 6-12 0-16"/>
  </g>
  <circle cx="40" cy="48" r="6" fill="url(#g)"/>`,
  // Scarab beetle
  scarab: `<g fill="url(#g)">
    <ellipse cx="50" cy="56" rx="20" ry="26"/>
    <path d="M50 30c-9 0-15 5-15 11 0 4 7 6 15 6s15-2 15-6c0-6-6-11-15-11Z"/>
  </g>
  <g fill="none" stroke="url(#g)" stroke-width="4" stroke-linecap="round">
    <path d="M50 34V80"/>
    <path d="M30 44 14 36M30 56 12 56M32 70 18 78"/>
    <path d="M70 44 86 36M70 56 88 56M68 70 82 78"/>
  </g>`,
  // Anubis — jackal head
  anubis: `<path fill="url(#g)" d="M30 14c2 8 1 16-2 24-4 10-6 20-4 30 1 8 6 14 13 16 2 4 6 6 11 6 3 0 5-2 5-4 0-3-2-4-5-5-4-1-7-3-8-7 7-2 12-7 14-15 3-12 1-24-5-35-3-6-4-12-3-18 0-3-2-5-5-6-4-1-8 1-9 4-2-3-5-4-8-3-2 1-3 3-2 5 4 2 6 5 5 9Z"/>
    <circle cx="40" cy="46" r="3.5" fill="#0A0806"/>`,
  // Horus — falcon head
  horus: `<path fill="url(#g)" d="M34 20c10-2 20 2 26 11 4 6 6 13 6 21 0 3 2 5 5 6 4 1 8 3 10 7-5 1-9 0-13-2-1 9-7 16-16 19-12 4-25-2-30-14-4-10-3-21 3-30 4-6 5-12 3-18-1-3 2-6 6-6Z"/>
    <circle cx="46" cy="40" r="4.5" fill="#0A0806"/>
    <path fill="#0A0806" d="M44 48c8 1 14 4 18 9-7-2-13-3-18-2Z"/>`,
  // Lotus
  lotus: `<g fill="url(#g)">
    <path d="M50 86C40 70 38 54 50 36 62 54 60 70 50 86Z"/>
    <path d="M50 84C36 76 28 62 28 44 44 50 52 64 50 84Z"/>
    <path d="M50 84C64 76 72 62 72 44 56 50 48 64 50 84Z"/>
    <path d="M50 82C32 80 18 70 12 54 30 52 46 62 50 82Z" opacity=".75"/>
    <path d="M50 82C68 80 82 70 88 54 70 52 54 62 50 82Z" opacity=".75"/>
  </g>`,
};

const inner = G[name] ?? "";
---
<svg viewBox="0 0 100 100" class={className} role={title ? "img" : "presentation"} aria-hidden={title ? undefined : "true"} aria-label={title || undefined} set:html={inner}></svg>
