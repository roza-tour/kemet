---
// Home hero — cinematic editorial: full-bleed photography, dark veil, inset
// hairline frame, the brand tagline as a true H1, lede and actions. The old
// plaque lockup is retired; the tagline carries the brand voice.
import { site } from "@/config/site";
---
<header class="hero">
  <div class="bg">
    <img
      src="/images/giza/giza-great-pyramid-clear-sky.webp"
      alt=""
      aria-hidden="true"
      width="1600"
      height="1062"
      fetchpriority="high"
    />
  </div>
  <div class="veil" aria-hidden="true"></div>
  <div class="hframe" aria-hidden="true"></div>
  <div class="hero-inner wrap">
    <div class="kicker"><span class="kline" aria-hidden="true"></span><span class="eyebrow">{site.eyebrow}</span></div>
    <h1>The Land. The Legacy.<br /><em>The Journey.</em></h1>
    <p class="lede">
      Egypt is not one country but eight cultural worlds layered along a single
      river. Kemet designs private, unhurried journeys through them — from the
      Pyramids of Giza and the temples of Luxor to a Nile cruise down to Aswan —
      each led by a licensed Egyptologist and shaped entirely around you.
    </p>
    <div class="hero-actions">
      <a href="tours.html" class="btn btn-solid">Explore the Journeys</a>
      <a href="identities.html" class="btn btn-ghost">The 8 Identities</a>
    </div>
  </div>
  <div class="hfoot" aria-hidden="true">
    <span>Est. Cairo — {site.meaning}</span>
    <span class="mid">Scroll<i></i></span>
    <span class="end">Tailor-made · Private · Five-Star</span>
  </div>
</header>
