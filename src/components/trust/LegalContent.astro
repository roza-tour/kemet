---
// LegalContent — renders a LegalDoc (privacy / terms) as an editorial article:
// a sticky, numbered table of contents beside gold-numeralled sections.
import type { LegalDoc } from "@/data/legal";
interface Props {
  doc: LegalDoc;
}
const { doc } = Astro.props;
const pad2 = (n: number) => String(n).padStart(2, "0");
---
<div class="legal-layout">
  <aside class="legal-toc" aria-label="Contents">
    <div class="legal-toc-inner">
      <div class="eyebrow">Contents</div>
      <ol>
        {doc.sections.map((s, i) => (
          <li><a href={`#s-${i + 1}`}><span class="legal-tnum">{pad2(i + 1)}</span>{s.heading}</a></li>
        ))}
      </ol>
      <div class="legal-updated">Last updated<br /><b>{doc.lastUpdated}</b></div>
    </div>
  </aside>

  <article class="legal-body reveal">
    <p class="legal-intro">{doc.intro}</p>
    {doc.sections.map((s, i) => (
      <section id={`s-${i + 1}`} class="legal-sec">
        <div class="legal-sec-head">
          <span class="legal-num">{pad2(i + 1)}</span>
          <h2>{s.heading}</h2>
        </div>
        {s.body.map((p) => <p>{p}</p>)}
      </section>
    ))}
  </article>
</div>

<style>
  .legal-layout{display:grid;grid-template-columns:250px 1fr;gap:64px;align-items:start;max-width:1000px;margin:0 auto}

  /* Sticky numbered table of contents */
  .legal-toc-inner{position:sticky;top:110px}
  .legal-toc .eyebrow{margin-bottom:20px}
  .legal-toc ol{list-style:none;margin:0;padding:0;counter-reset:none}
  .legal-toc li{margin:0}
  .legal-toc a{display:flex;gap:12px;align-items:baseline;padding:9px 0;font-size:.86rem;color:var(--muted-2);border-bottom:1px solid var(--line);transition:color .3s}
  .legal-toc a:hover{color:var(--gold-bright)}
  .legal-tnum{font-family:var(--ff-display);font-size:.8rem;color:var(--gold-deep);min-width:22px;font-variant-numeric:tabular-nums}
  .legal-updated{margin-top:26px;font-size:.7rem;letter-spacing:.14em;text-transform:uppercase;color:var(--muted-2);line-height:2}
  .legal-updated b{color:var(--gold);letter-spacing:.06em}

  /* Body */
  .legal-body{max-width:680px}
  .legal-intro{font-family:var(--ff-display);font-size:1.35rem;line-height:1.6;color:var(--bone);font-weight:300;margin-bottom:16px;padding-bottom:36px;border-bottom:1px solid var(--line)}
  .legal-sec{padding:38px 0;border-bottom:1px solid var(--line)}
  .legal-sec:last-child{border-bottom:0}
  .legal-sec-head{display:flex;align-items:baseline;gap:18px;margin-bottom:18px}
  .legal-num{font-family:var(--ff-display);font-size:1.5rem;color:var(--gold);line-height:1;font-variant-numeric:tabular-nums;flex:none}
  .legal-sec-head h2{font-size:1.4rem;color:var(--bone);margin:0}
  .legal-sec p{color:var(--muted);margin:0 0 14px;line-height:1.9}
  .legal-sec p:last-child{margin-bottom:0}

  @media(max-width:860px){
    .legal-layout{grid-template-columns:1fr;gap:34px}
    .legal-toc-inner{position:static}
    .legal-toc ol{columns:2;column-gap:26px}
    .legal-body{max-width:none}
  }
  @media(max-width:520px){.legal-toc ol{columns:1}}
</style>
