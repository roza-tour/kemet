---
// LegalContent — renders a LegalDoc (privacy / terms) as a readable article.
import type { LegalDoc } from "@/data/legal";
interface Props {
  doc: LegalDoc;
}
const { doc } = Astro.props;
---
<article class="legal">
  <p class="legal-updated">Last updated: {doc.lastUpdated}</p>
  <p class="legal-intro">{doc.intro}</p>
  {doc.sections.map((s, i) => (
    <section class="legal-sec">
      <h2>{`${i + 1}. ${s.heading}`}</h2>
      {s.body.map((p) => <p>{p}</p>)}
    </section>
  ))}
</article>

<style>
  .legal{max-width:760px;margin:0 auto}
  .legal-updated{font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;color:var(--muted-2);margin:0 0 20px}
  .legal-intro{font-size:1.08rem;color:var(--muted);margin:0 0 12px}
  .legal-sec{margin-top:34px}
  .legal-sec h2{font-size:1.25rem;margin:0 0 12px}
  .legal-sec p{color:var(--muted);margin:0 0 12px}
  .legal-sec p:last-child{margin-bottom:0}
</style>
