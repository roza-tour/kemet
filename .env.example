# Kemet — deploy-time configuration. Copy to `.env` and fill in for production.
# All values are optional; without them the build falls back to the placeholders
# in src/config/site.ts (and astro.config.mjs for the URL), so a default build
# still works. Variables must be prefixed PUBLIC_ to reach client code.

# Live site origin (no trailing slash). Drives canonical URLs, Open Graph,
# the sitemap and JSON-LD. Keep in sync across the build by setting it here.
PUBLIC_SITE_URL=https://kemet-travel.com

# WhatsApp number in international format, digits only (used for wa.me links).
PUBLIC_WHATSAPP=201000000000

# Public contact details.
PUBLIC_CONTACT_EMAIL=info@kemet-travel.com
PUBLIC_CONTACT_PHONE=+20 100 000 0000
