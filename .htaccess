<IfModule mod_rewrite.c>
        RewriteEngine On
        # Force HTTPS
        RewriteCond %{HTTPS} off
        RewriteCond %{HTTP:X-Forwarded-SSL} !on
        RewriteRule ^(.*)$ "https://%{HTTP_HOST}%{REQUEST_URI}" [R=301,L]
</IfModule>
### AutoSSL-Satellite Don't Edit Above This Line ###

# ---------------------------------------------------------------------------
# Kemet — served from the repo root of `main` (single-branch deployment).
# The built site and the Astro source live side by side; this file makes sure
# visitors only ever see the site, and fixes the SEO redirects.
#
# IMPORTANT: cPanel's AutoSSL writes its HTTPS-force block at the VERY TOP of
# this file. It must stay there (with its markers, above) so AutoSSL detects
# its own block and never prepends a duplicate — a duplicate dirties the git
# checkout and blocks `git pull` on the server.
# ---------------------------------------------------------------------------

Options -Indexes

RewriteEngine On

# www → apex domain (301), keeping one canonical host.
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

# Legacy extensionless URLs (old sitemap) → their real .html pages (301).
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^([^.]+?)/?$ $1.html [R=301,L]

# Repo internals are not part of the website — hide them completely (404).
RewriteRule ^(?:\.git|src|scripts|public|node_modules|dist|\.claude|\.astro)(/|$) - [R=404,L]

# Project/config files that sit in the repo root must never be downloadable.
<FilesMatch "^(package(-lock)?\.json|astro\.config\.mjs|tsconfig\.json|README\.md|DEPLOYMENT\.md|ARCHITECTURE\.md|\.env.*|\.gitignore|\.publish-manifest)$">
  Require all denied
</FilesMatch>

# Astro source that co-lives in the repo root must never be served, even if a
# new source file ever lands outside the folders blocked above.
<FilesMatch "\.(ts|astro|mjs)$">
  Require all denied
</FilesMatch>
